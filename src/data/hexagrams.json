[
  {"id":1,"name":"乾为天","upper":"乾","lower":"乾","lines":[1,1,1,1,1,1],"palace":"乾","shi":5,"ying":2,"desc":"元亨利贞。","judgment":"大哉乾元，万物资始，乃统天。","image":"天行健，君子以自强不息。"},
  {"id":2,"name":"坤为地","upper":"坤","lower":"坤","lines":[0,0,0,0,0,0],"palace":"坤","shi":5,"ying":2,"desc":"元亨，利牝马之贞。","judgment":"至哉坤元，万物资生，乃顺承天。","image":"地势坤，君子以厚德载物。"},
  {"id":3,"name":"水雷屯","upper":"坎","lower":"震","lines":[0,0,1,0,1,0],"palace":"坎","shi":1,"ying":4,"desc":"元亨利贞。勿用有攸往，利建侯。","judgment":"屯，刚柔始交而难生。","image":"云雷屯，君子以经纶。"},
  {"id":4,"name":"山水蒙","upper":"艮","lower":"坎","lines":[0,1,0,1,0,0],"palace":"离","shi":3,"ying":5,"desc":"亨。匪我求童蒙，童蒙求我。","judgment":"蒙，山下有险，险而止蒙。","image":"山下出泉蒙，君子以果行育德。"},
  {"id":5,"name":"水天需","upper":"坎","lower":"乾","lines":[1,1,1,0,1,0],"palace":"坤","shi":3,"ying":5,"desc":"有孚，光亨，贞吉。利涉大川。","judgment":"需，须也。险在前也。","image":"云上于天需，君子以饮食宴乐。"},
  {"id":6,"name":"天水讼","upper":"乾","lower":"坎","lines":[0,1,0,1,1,1],"palace":"离","shi":3,"ying":5,"desc":"有孚窒惕，中吉终凶。利见大人，不利涉大川。","judgment":"讼，上刚下险，险而健讼。","image":"天与水违行讼，君子以作事谋始。"},
  {"id":7,"name":"地水师","upper":"坤","lower":"坎","lines":[0,1,0,0,0,0],"palace":"坎","shi":2,"ying":5,"desc":"贞，丈人吉无咎。","judgment":"师，众也。贞，正也。","image":"地中有水师，君子以容民畜众。"},
  {"id":8,"name":"水地比","upper":"坎","lower":"坤","lines":[0,0,0,0,1,0],"palace":"坤","shi":2,"ying":5,"desc":"吉。原筮元永贞无咎。","judgment":"比，吉也。比，辅也。","image":"地上有水比，先王以建万国亲诸侯。"},
  {"id":9,"name":"风天小畜","upper":"巽","lower":"乾","lines":[1,1,1,1,1,0],"palace":"巽","shi":0,"ying":3,"desc":"亨。密云不雨，自我西郊。","judgment":"小畜，柔得位而上下应之。","image":"风行天上小畜，君子以懿文德。"},
  {"id":10,"name":"天泽履","upper":"乾","lower":"兑","lines":[0,1,1,1,1,1],"palace":"艮","shi":4,"ying":1,"desc":"履虎尾，不咥人，亨。","judgment":"履，柔履刚也。","image":"上天下泽履，君子以辩上下定民志。"},
  {"id":11,"name":"地天泰","upper":"坤","lower":"乾","lines":[1,1,1,0,0,0],"palace":"坤","shi":2,"ying":5,"desc":"小往大来，吉亨。","judgment":"泰，小往大来，吉亨。","image":"天地交泰，后以财成天地之道。"},
  {"id":12,"name":"天地否","upper":"乾","lower":"坤","lines":[0,0,0,1,1,1],"palace":"乾","shi":2,"ying":5,"desc":"否之匪人，不利君子贞，大往小来。","judgment":"否之匪人，不利君子贞。","image":"天地不交否，君子以俭德辟难。"},
  {"id":13,"name":"天火同人","upper":"乾","lower":"离","lines":[1,0,1,1,1,1],"palace":"离","shi":2,"ying":5,"desc":"同人于野，亨。利涉大川，利君子贞。","judgment":"同人，柔得位得中而应乎乾。","image":"天与火同人，君子以类族辨物。"},
  {"id":14,"name":"火天大有","upper":"离","lower":"乾","lines":[1,1,1,1,0,1],"palace":"乾","shi":2,"ying":5,"desc":"元亨。","judgment":"大有，柔得尊位大中而上下应之。","image":"火在天上大有，君子以遏恶扬善。"},
  {"id":15,"name":"地山谦","upper":"坤","lower":"艮","lines":[1,0,0,0,0,0],"palace":"兑","shi":4,"ying":1,"desc":"亨，君子有终。","judgment":"谦亨，天道下济而光明。","image":"地中有山谦，君子以裒多益寡。"},
  {"id":16,"name":"雷地豫","upper":"震","lower":"坤","lines":[0,0,0,0,0,1],"palace":"震","shi":0,"ying":3,"desc":"利建侯行师。","judgment":"豫，刚应而志行。","image":"雷出地奋豫，先王以作乐崇德。"},
  {"id":17,"name":"泽雷随","upper":"兑","lower":"震","lines":[0,0,1,0,1,1],"palace":"震","shi":2,"ying":5,"desc":"元亨利贞，无咎。","judgment":"随，刚来而下柔，动而说随。","image":"泽中有雷随，君子以向晦入宴息。"},
  {"id":18,"name":"山风蛊","upper":"艮","lower":"巽","lines":[1,1,0,1,0,0],"palace":"巽","shi":2,"ying":5,"desc":"元亨，利涉大川。先甲三日，后甲三日。","judgment":"蛊，刚上而柔下，巽而止蛊。","image":"山下有风蛊，君子以振民育德。"},
  {"id":19,"name":"地泽临","upper":"坤","lower":"兑","lines":[0,1,1,0,0,0],"palace":"坤","shi":1,"ying":4,"desc":"元亨利贞。至于八月有凶。","judgment":"临，刚浸而长。","image":"泽上有地临，君子以教思无穷。"},
  {"id":20,"name":"风地观","upper":"巽","lower":"坤","lines":[0,0,0,0,1,1],"palace":"乾","shi":3,"ying":0,"desc":"盥而不荐，有孚颙若。","judgment":"大观在上，顺而巽，中正以观天下。","image":"风行地上观，先王以省方观民设教。"},
  {"id":21,"name":"火雷噬嗑","upper":"离","lower":"震","lines":[0,0,1,1,0,1],"palace":"巽","shi":4,"ying":1,"desc":"亨，利用狱。","judgment":"颐中有物曰噬嗑。","image":"雷电噬嗑，先王以明罚敕法。"},
  {"id":22,"name":"山火贲","upper":"艮","lower":"离","lines":[1,0,1,1,0,0],"palace":"艮","shi":0,"ying":3,"desc":"亨。小利有攸往。","judgment":"贲亨，柔来而文刚。","image":"山下有火贲，君子以明庶政。"},
  {"id":23,"name":"山地剥","upper":"艮","lower":"坤","lines":[0,0,0,0,0,1],"palace":"乾","shi":4,"ying":1,"desc":"不利有攸往。","judgment":"剥，剥也。柔变刚也。","image":"山附于地剥，上以厚下安宅。"},
  {"id":24,"name":"地雷复","upper":"坤","lower":"震","lines":[0,0,1,0,0,0],"palace":"坤","shi":0,"ying":3,"desc":"亨。出入无疾，朋来无咎。","judgment":"复亨，刚反。","image":"雷在地中复，先王以至日闭关。"},
  {"id":25,"name":"天雷无妄","upper":"乾","lower":"震","lines":[0,0,1,1,1,1],"palace":"巽","shi":3,"ying":0,"desc":"元亨利贞。其匪正有眚，不利有攸往。","judgment":"无妄，刚自外来而为主于内。","image":"天下雷行物与无妄，先王以茂对时育万物。"},
  {"id":26,"name":"山天大畜","upper":"艮","lower":"乾","lines":[1,1,1,1,0,0],"palace":"艮","shi":1,"ying":4,"desc":"利贞。不家食吉，利涉大川。","judgment":"大畜，刚健笃实辉光。","image":"天在山中大畜，君子以多识前言往行。"},
  {"id":27,"name":"山雷颐","upper":"艮","lower":"震","lines":[0,0,1,1,0,0],"palace":"巽","shi":3,"ying":0,"desc":"贞吉。观颐，自求口实。","judgment":"颐贞吉，养正则吉也。","image":"山下有雷颐，君子以慎言语节饮食。"},
  {"id":28,"name":"泽风大过","upper":"兑","lower":"巽","lines":[1,1,0,0,1,1],"palace":"震","shi":3,"ying":0,"desc":"栋桡，利有攸往，亨。","judgment":"大过，大者过也。","image":"泽灭木大过，君子以独立不惧。"},
  {"id":29,"name":"坎为水","upper":"坎","lower":"坎","lines":[0,1,0,0,1,0],"palace":"坎","shi":5,"ying":2,"desc":"习坎，有孚维心亨，行有尚。","judgment":"习坎，重险也。","image":"水洊至习坎，君子以常德行习教事。"},
  {"id":30,"name":"离为火","upper":"离","lower":"离","lines":[1,0,1,1,0,1],"palace":"离","shi":5,"ying":2,"desc":"利贞，亨。畜牝牛吉。","judgment":"离，丽也。日月丽乎天。","image":"明两作离，大人以继明照于四方。"},
  {"id":31,"name":"泽山咸","upper":"兑","lower":"艮","lines":[1,0,0,0,1,1],"palace":"兑","shi":2,"ying":5,"desc":"亨利贞，取女吉。","judgment":"咸，感也。柔上而刚下。","image":"山上有泽咸，君子以虚受人。"},
  {"id":32,"name":"雷风恒","upper":"震","lower":"巽","lines":[1,1,0,0,0,1],"palace":"震","shi":2,"ying":5,"desc":"亨，无咎，利贞，利有攸往。","judgment":"恒，久也。","image":"雷风恒，君子以立不易方。"},
  {"id":33,"name":"天山遁","upper":"乾","lower":"艮","lines":[1,0,0,1,1,1],"palace":"乾","shi":1,"ying":4,"desc":"亨，小利贞。","judgment":"遁亨，遁而亨也。","image":"天下有山遁，君子以远小人。"},
  {"id":34,"name":"雷天大壮","upper":"震","lower":"乾","lines":[1,1,1,1,0,0],"palace":"坤","shi":3,"ying":0,"desc":"利贞。","judgment":"大壮，大者壮也。","image":"雷在天上大壮，君子以非礼弗履。"},
  {"id":35,"name":"火地晋","upper":"离","lower":"坤","lines":[0,0,0,1,0,1],"palace":"乾","shi":3,"ying":0,"desc":"康侯用锡马蕃庶，昼日三接。","judgment":"晋，进也。","image":"明出地上晋，君子以自昭明德。"},
  {"id":36,"name":"地火明夷","upper":"坤","lower":"离","lines":[1,0,1,0,0,0],"palace":"坎","shi":3,"ying":0,"desc":"利艰贞。","judgment":"明入地中明夷。","image":"明入地中明夷，君子以莅众用晦而明。"},
  {"id":37,"name":"风火家人","upper":"巽","lower":"离","lines":[1,0,1,1,1,0],"palace":"巽","shi":1,"ying":4,"desc":"利女贞。","judgment":"家人，女正位乎内，男正位乎外。","image":"风自火出家人，君子以言有物而行有恒。"},
  {"id":38,"name":"火泽睽","upper":"离","lower":"兑","lines":[0,1,1,1,0,1],"palace":"艮","shi":3,"ying":0,"desc":"小事吉。","judgment":"睽，火动而上，泽动而下。","image":"上火下泽睽，君子以同而异。"},
  {"id":39,"name":"水山蹇","upper":"坎","lower":"艮","lines":[1,0,0,0,1,0],"palace":"兑","shi":3,"ying":0,"desc":"利西南，不利东北。利见大人，贞吉。","judgment":"蹇，难也，险在前也。","image":"山上有水蹇，君子以反身修德。"},
  {"id":40,"name":"雷水解","upper":"震","lower":"坎","lines":[0,1,0,0,0,1],"palace":"震","shi":1,"ying":4,"desc":"利西南，无所往，其来复吉。","judgment":"解，险以动，动而免乎险。","image":"雷雨作解，君子以赦过宥罪。"},
  {"id":41,"name":"山泽损","upper":"艮","lower":"兑","lines":[0,1,1,1,0,0],"palace":"艮","shi":2,"ying":5,"desc":"有孚，元吉，无咎，可贞，利有攸往。","judgment":"损，损下益上，其道上行。","image":"山下有泽损，君子以惩忿窒欲。"},
  {"id":42,"name":"风雷益","upper":"巽","lower":"震","lines":[0,0,1,1,1,0],"palace":"巽","shi":2,"ying":5,"desc":"利有攸往，利涉大川。","judgment":"益，损上益下，民说无疆。","image":"风雷益，君子以见善则迁。"},
  {"id":43,"name":"泽天夬","upper":"兑","lower":"乾","lines":[1,1,1,1,1,0],"palace":"坤","shi":4,"ying":1,"desc":"扬于王庭，孚号有厉。","judgment":"夬，决也，刚决柔也。","image":"泽上于天夬，君子以施禄及下。"},
  {"id":44,"name":"天风姤","upper":"乾","lower":"巽","lines":[1,1,0,1,1,1],"palace":"乾","shi":0,"ying":3,"desc":"女壮，勿用取女。","judgment":"姤，遇也，柔遇刚也。","image":"天下有风姤，后以施命诰四方。"},
  {"id":45,"name":"泽地萃","upper":"兑","lower":"坤","lines":[0,0,0,1,1,0],"palace":"兑","shi":1,"ying":4,"desc":"亨。王假有庙。利见大人。","judgment":"萃，聚也。","image":"泽上于地萃，君子以除戎器戒不虞。"},
  {"id":46,"name":"地风升","upper":"坤","lower":"巽","lines":[1,1,0,0,0,0],"palace":"震","shi":3,"ying":0,"desc":"元亨，用见大人，勿恤，南征吉。","judgment":"柔以时升。","image":"地中生木升，君子以顺德积小以高大。"},
  {"id":47,"name":"泽水困","upper":"兑","lower":"坎","lines":[0,1,0,0,1,1],"palace":"兑","shi":0,"ying":3,"desc":"亨，贞，大人吉无咎。有言不信。","judgment":"困，刚揜也。","image":"泽无水困，君子以致命遂志。"},
  {"id":48,"name":"水风井","upper":"坎","lower":"巽","lines":[1,1,0,0,1,0],"palace":"震","shi":4,"ying":1,"desc":"改邑不改井，无丧无得。","judgment":"巽乎水而上水井。","image":"木上有水井，君子以劳民劝相。"},
  {"id":49,"name":"泽火革","upper":"兑","lower":"离","lines":[1,0,1,1,1,0],"palace":"坎","shi":3,"ying":0,"desc":"己日乃孚，元亨利贞，悔亡。","judgment":"革，水火相息。","image":"泽中有火革，君子以治历明时。"},
  {"id":50,"name":"火风鼎","upper":"离","lower":"巽","lines":[1,1,0,1,0,1],"palace":"离","shi":1,"ying":4,"desc":"元吉，亨。","judgment":"鼎，象也。以木巽火，亨饪也。","image":"木上有火鼎，君子以正位凝命。"},
  {"id":51,"name":"震为雷","upper":"震","lower":"震","lines":[0,0,1,0,0,1],"palace":"震","shi":5,"ying":2,"desc":"亨。震来虩虩，笑言哑哑。","judgment":"震亨。","image":"洊雷震，君子以恐惧修省。"},
  {"id":52,"name":"艮为山","upper":"艮","lower":"艮","lines":[1,0,0,1,0,0],"palace":"艮","shi":5,"ying":2,"desc":"艮其背，不获其身。","judgment":"艮，止也。","image":"兼山艮，君子以思不出其位。"},
  {"id":53,"name":"风山渐","upper":"巽","lower":"艮","lines":[1,0,0,1,1,0],"palace":"艮","shi":2,"ying":5,"desc":"女归吉，利贞。","judgment":"渐之进也，女归吉也。","image":"山上有木渐，君子以居贤德善俗。"},
  {"id":54,"name":"雷泽归妹","upper":"震","lower":"兑","lines":[0,1,1,0,0,1],"palace":"兑","shi":2,"ying":5,"desc":"征凶，无攸利。","judgment":"归妹，天地之大义也。","image":"泽上有雷归妹，君子以永终知敝。"},
  {"id":55,"name":"雷火丰","upper":"震","lower":"离","lines":[1,0,1,0,0,1],"palace":"坎","shi":4,"ying":1,"desc":"亨，王假之，勿忧，宜日中。","judgment":"丰，大也。明以动故丰。","image":"雷电皆至丰，君子以折狱致刑。"},
  {"id":56,"name":"火山旅","upper":"离","lower":"艮","lines":[1,0,0,1,0,1],"palace":"离","shi":0,"ying":3,"desc":"小亨，旅贞吉。","judgment":"旅小亨。","image":"山上有火旅，君子以明慎用刑。"},
  {"id":57,"name":"巽为风","upper":"巽","lower":"巽","lines":[1,1,0,1,1,0],"palace":"巽","shi":5,"ying":2,"desc":"小亨，利有攸往，利见大人。","judgment":"重巽以申命。","image":"随风巽，君子以申命行事。"},
  {"id":58,"name":"兑为泽","upper":"兑","lower":"兑","lines":[0,1,1,0,1,1],"palace":"兑","shi":5,"ying":2,"desc":"亨，利贞。","judgment":"兑，说也。","image":"丽泽兑，君子以朋友讲习。"},
  {"id":59,"name":"风水涣","upper":"巽","lower":"坎","lines":[0,1,0,1,1,0],"palace":"离","shi":4,"ying":1,"desc":"亨。王假有庙，利涉大川。","judgment":"涣，亨。刚来而不穷。","image":"风行水上涣，先王以享于帝立庙。"},
  {"id":60,"name":"水泽节","upper":"坎","lower":"兑","lines":[0,1,1,0,1,0],"palace":"坎","shi":0,"ying":3,"desc":"亨。苦节不可贞。","judgment":"节，亨。刚柔分而刚得中。","image":"泽上有水节，君子以制数度议德行。"},
  {"id":61,"name":"风泽中孚","upper":"巽","lower":"兑","lines":[0,1,1,1,1,0],"palace":"艮","shi":3,"ying":0,"desc":"豚鱼吉，利涉大川，利贞。","judgment":"中孚，柔在内而刚得中。","image":"泽上有风中孚，君子以议狱缓死。"},
  {"id":62,"name":"雷山小过","upper":"震","lower":"艮","lines":[1,0,0,0,0,1],"palace":"兑","shi":3,"ying":0,"desc":"亨利贞，可小事，不可大事。","judgment":"小过，小者过而亨也。","image":"山上有雷小过，君子以行过乎恭。"},
  {"id":63,"name":"水火既济","upper":"坎","lower":"离","lines":[1,0,1,0,1,0],"palace":"坎","shi":2,"ying":5,"desc":"亨小，利贞。初吉终乱。","judgment":"既济，亨。小者亨也。","image":"水在火上既济，君子以思患而豫防之。"},
  {"id":64,"name":"火水未济","upper":"离","lower":"坎","lines":[0,1,0,1,0,1],"palace":"离","shi":2,"ying":5,"desc":"亨。小狐汔济，濡其尾。","judgment":"未济，亨。柔得中也。","image":"火在水上未济，君子以慎辨物居方。"}
]
